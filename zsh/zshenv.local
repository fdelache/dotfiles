# Environment variables for all shell types (interactive + non-interactive)
# Symlinked to ~/.zshenv by install/symlinks.sh

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# chruby
export PATH="/usr/local/share/chruby:$PATH"

# aliases
alias whatsup="DEV_NO_AUTO_UPDATE=1 dev ps --all-namespaces | grep running"
# git-remove-untracked lives in zsh/functions.zsh (World/wtp-aware version)
